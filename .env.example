# Override the Netlify edge-function host. If unset, src/lib/apiBase.ts
# falls back to the production deploy URL.
# VITE_API_BASE=https://your-netlify-deploy.netlify.app

# Force debug logging on in a production build. In dev (pnpm dev) logs
# from src/lib/debug.ts are always on; in prod they're off unless this
# is set to "true".
# VITE_DEBUG_LOGS=true

# Comma-separated list of origins the Netlify edge functions accept for
# CORS. Read by netlify/lib/cors.ts. Set this on Netlify (not in a local
# .env) to add a domain without redeploying. If unset, the in-code
# fallback list (localhost + the two prod domains) is used.
# ALLOWED_ORIGINS=https://your-domain.example,https://other-domain.example

# ---------------------------------------------------------------------------
# HuggingFace model selection
# ---------------------------------------------------------------------------
# Each var is read by both the client (via Vite's envPrefix in vite.config.ts)
# AND the Deno edge functions (via Deno.env.get). Fallbacks live in
# src/lib/modelConfig.ts; if you change a model, set the env var in Netlify
# and the client + edge function will both pick it up on next deploy.
#
# HF_EMBEDDING_MODEL=BAAI/bge-m3
# HF_CHAT_MODEL=meta-llama/Llama-3.3-70B-Instruct:ovhcloud
# HF_OPTIMIZER_MODEL=openai/gpt-oss-20b:ovhcloud
